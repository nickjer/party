<%# locals: () %>

<dialog
  data-dialog-target="dialog"
  data-action="click->dialog#backdropClose"
  class="cn-dialog border-0 p-0 rounded-4 shadow-lg"
  style="max-width: 32rem;"
>
  <div class="p-4">
    <div class="d-flex justify-content-between align-items-start mb-3">
      <h1 class="fs-5 fw-bold mb-0">
        <i class="bi bi-info-circle me-2"></i>
        How to play
      </h1>
      <button
        type="button"
        class="btn-close"
        data-action="dialog#close"
        aria-label="Close"
      ></button>
    </div>

    <p class="text-secondary small">
      This app runs the board, the secret key, turn order, and scoring.
      Clues are spoken out loud — never typed here.
    </p>

    <div class="d-flex gap-3 mb-3">
      <i class="bi bi-binoculars-fill fs-4 text-secondary"></i>
      <div>
        <div class="fw-semibold">Spymasters (one per team)</div>
        <p class="mb-0 small text-secondary">
          Tap <strong>Show key</strong> to see which cards are yours. On your
          team's turn, say <strong>one word</strong> plus a
          <strong>number</strong> — e.g. <em>"Ocean, 2"</em> — where the number
          is how many cards on the board relate to that word. Nothing else.
        </p>
      </div>
    </div>

    <div class="d-flex gap-3 mb-3">
      <i class="bi bi-hand-index-fill fs-4 text-secondary"></i>
      <div>
        <div class="fw-semibold">Operatives</div>
        <p class="mb-1 small text-secondary">
          Tap the cards you think your spymaster meant:
        </p>
        <ul class="small text-secondary mb-1 ps-3">
          <li>Your team's agent → keep guessing.</li>
          <li>A bystander or the other team's agent → your turn ends.</li>
          <li>The assassin → your team loses instantly.</li>
        </ul>
        <p class="mb-0 small text-secondary">
          You may guess up to the clue's number, <strong>plus one</strong> bonus
          guess (so <em>"Ocean, 2"</em> allows up to 3). Stop any time, or tap
          <strong>End turn</strong> when you're done.
        </p>
      </div>
    </div>

    <div class="d-flex gap-3">
      <i class="bi bi-trophy-fill fs-4 text-secondary"></i>
      <div>
        <div class="fw-semibold">Goal</div>
        <p class="mb-0 small text-secondary">
          The first team to reveal all of their agents wins.
        </p>
      </div>
    </div>
  </div>
</dialog>
