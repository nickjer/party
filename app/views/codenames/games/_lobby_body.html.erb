<%# locals: (game:, current_player:, start_game: nil, join_team: nil) %>

<div class="mt-2">
  <div class="d-flex align-items-center justify-content-between mb-2">
    <h1 class="h4 text-success mb-0">
      <i class="bi bi-grid-3x3-gap-fill me-2"></i>
      Codenames
    </h1>
    <span class="text-muted small">Pick a team to begin</span>
  </div>

  <% if start_game&.errors&.full_messages&.any? %>
    <div class="alert alert-warning py-2">
      <% start_game.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  <% end %>

  <% if join_team&.errors&.full_messages&.any? %>
    <div class="alert alert-warning py-2">
      <% join_team.errors.full_messages.each do |message| %>
        <div><%= message %></div>
      <% end %>
    </div>
  <% end %>

  <%= render "codenames/games/team_panels", game:, current_player: %>
</div>
